# Server
PORT=3000
ENV=development

# Database
# Use "sqlite" for SQLite (no PostgreSQL needed)
# Or set to "localhost" for PostgreSQL
DB_HOST=sqlite
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=vpn_3wg

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRY=24h

# Admin
ADMIN_EMAIL=admin@3wg.ru
ADMIN_PASSWORD=admin123

# Payment APIs
# YooKassa (приоритетный провайдер для российского рынка)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Cryptomus (fallback провайдер для криптовалют)
CRYPTOMUS_API_KEY=your_api_key
CRYPTOMUS_MERCHANT_ID=your_merchant_id

# URLs
BASE_URL=http://localhost:8080
API_URL=http://localhost:3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=
